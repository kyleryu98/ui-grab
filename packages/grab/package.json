{
  "name": "ui-grab",
  "version": "0.1.30",
  "description": "Open-source UI context picker for coding agents with built-in Shift multi-select",
  "keywords": [
    "agent",
    "codex",
    "context",
    "copilot",
    "cursor",
    "grab",
    "react",
    "react-grab",
    "ui-grab"
  ],
  "homepage": "https://github.com/Yongtaek-Ryu/ui-grab",
  "bugs": {
    "url": "https://github.com/Yongtaek-Ryu/ui-grab/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Yongtaek Ryu"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Yongtaek-Ryu/ui-grab.git"
  },
  "bin": {
    "ui-grab": "bin/cli.js"
  },
  "files": [
    "bin",
    "dist",
    "package.json",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "browser": "dist/index.global.js",
  "types": "dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./core": {
      "import": {
        "types": "./dist/core/index.d.ts",
        "default": "./dist/core/index.js"
      },
      "require": {
        "types": "./dist/core/index.d.cts",
        "default": "./dist/core/index.cjs"
      }
    },
    "./primitives": {
      "import": {
        "types": "./dist/primitives.d.ts",
        "default": "./dist/primitives.js"
      },
      "require": {
        "types": "./dist/primitives.d.cts",
        "default": "./dist/primitives.cjs"
      }
    },
    "./styles.css": "./dist/styles.css",
    "./dist/styles.css": "./dist/styles.css",
    "./dist/*": "./dist/*.js",
    "./dist/*.js": "./dist/*.js",
    "./dist/*.cjs": "./dist/*.cjs"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "node scripts/build.js"
  },
  "dependencies": {
    "@antfu/ni": "^0.23.0",
    "commander": "^14.0.0",
    "ignore": "^7.0.5",
    "jsonc-parser": "^3.3.1",
    "ora": "^8.2.0",
    "picocolors": "^1.1.1",
    "prompts": "^2.4.2",
    "smol-toml": "^1.6.0",
    "@medv/finder": "^4.0.2",
    "bippy": "^0.5.32",
    "element-source": "^0.0.3",
    "solid-js": "^1.9.10"
  },
  "peerDependencies": {
    "react": ">=17.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=18"
  }
}
