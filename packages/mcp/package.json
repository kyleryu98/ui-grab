{
  "name": "ui-grab-mcp",
  "version": "0.1.35",
  "bin": {
    "ui-grab-mcp": "bin/ui-grab-mcp.cjs"
  },
  "files": [
    "bin",
    "dist",
    "package.json",
    "README.md",
    "LICENSE"
  ],
  "description": "Optional MCP bridge for ui-grab",
  "license": "MIT",
  "homepage": "https://github.com/kyleryu98/ui-grab",
  "bugs": {
    "url": "https://github.com/kyleryu98/ui-grab/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kyleryu98/ui-grab.git"
  },
  "type": "module",
  "browser": "dist/client.global.js",
  "exports": {
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js",
      "require": "./dist/client.cjs"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js",
      "require": "./dist/server.cjs"
    },
    "./dist/*": "./dist/*.js",
    "./dist/*.js": "./dist/*.js"
  },
  "scripts": {
    "dev": "tsup --watch",
    "build": "pnpm --filter ui-grab build && rm -rf dist && NODE_ENV=production tsup",
    "prepack": "pnpm build && node scripts/prepare-package-manifest.js",
    "postpack": "node scripts/restore-package-manifest.js",
    "test": "node --test test/*.test.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.25.0",
    "fkill": "^9.0.0",
    "ui-grab": "workspace:*",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "tsup": "^8.4.0"
  }
}
